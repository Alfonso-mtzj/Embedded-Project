// Fill a rectangle with a solid color
void LCD_FillRect(uint8_t x, uint8_t y, uint8_t w, uint8_t h, uint16_t color) {
    uint8_t i, j;
    for (j = y; j < y + h; j++) {
        for (i = x; i < x + w; i++) {
            LCD_WritePixel(i, j, color);
        }
    }
    // TODO: Replace the loop above with a faster driver rectangle fill if available.
    // e.g.: Graphics_Rectangle rect = {x, y, x+w-1, y+h-1};
    //        Graphics_setForegroundColor(&g_sContext, color);
    //        Graphics_fillRectangle(&g_sContext, &rect);
}

// Bresenham line
void LCD_DrawLine(uint8_t x0, uint8_t y0, uint8_t x1, uint8_t y1, uint16_t color) {
    int dx  =  (x1 > x0) ? (x1 - x0) : (x0 - x1);
    int dy  = -((y1 > y0) ? (y1 - y0) : (y0 - y1));
    int sx  = (x0 < x1) ? 1 : -1;
    int sy  = (y0 < y1) ? 1 : -1;
    int err = dx + dy;
    int e2;
    while (1) {
        LCD_WritePixel(x0, y0, color);
        if (x0 == x1 && y0 == y1) break;
        e2 = 2 * err;
        if (e2 >= dy) { err += dy; x0 += sx; }
        if (e2 <= dx) { err += dx; y0 += sy; }
    }
}

// Draw a single ASCII character using the 5x7 font
// Each column byte: bit7 = top, bit0 = bottom
void LCD_DrawChar(uint8_t x, uint8_t y, char c, uint16_t fg, uint16_t bg) {
    uint8_t col, row;
    int idx = (int)c - 32;
    if (idx < 0 || idx >= (int)(sizeof(font5x7)/sizeof(font5x7[0]))) idx = 0;
    for (col = 0; col < 5; col++) {
        uint8_t col_data = font5x7[idx][col];
        for (row = 0; row < 7; row++) {
            LCD_WritePixel(x + col, y + row,
                (col_data & (0x80 >> row)) ? fg : bg);
        }
    }
    // 1-pixel spacer column
    for (row = 0; row < 7; row++) {
        LCD_WritePixel(x + 5, y + row, bg);
    }
}

void LCD_DrawString(uint8_t x, uint8_t y, const char *s, uint16_t fg, uint16_t bg) {
    while (*s) {
        LCD_DrawChar(x, y, *s, fg, bg);
        x += 6;   // 5 pixels + 1 spacer
        s++;
        if (x >= 122) break;  // don't overrun screen
    }
}
