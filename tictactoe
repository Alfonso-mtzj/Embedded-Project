// ============================================================
//  Board Layout on 128x128 LCD
//  The 3x3 grid is drawn centered on screen.
//  Each cell is CELL_SIZE x CELL_SIZE pixels.
//  Grid lines are LINE_THICK pixels wide.
// ============================================================
#define CELL_SIZE       38          // pixels per cell
#define LINE_THICK      2           // grid line thickness
#define GRID_OFFSET_X   7           // left margin before grid
#define GRID_OFFSET_Y   20          // top margin (leaves room for status bar)
#define GRID_TOTAL      (CELL_SIZE * 3 + LINE_THICK * 2)  // ~118 px wide

// ============================================================
//  Colors (RGB565 format used by Crystalfontz 128x128 LCD)
// ============================================================
#define COLOR_BLACK     0x0000
#define COLOR_WHITE     0xFFFF
#define COLOR_RED       0xF800
#define COLOR_BLUE      0x001F
#define COLOR_GREEN     0x07E0
#define COLOR_YELLOW    0xFFE0
#define COLOR_GRAY      0x8410
#define COLOR_DGRAY     0x4208
#define COLOR_CYAN      0x07FF
#define COLOR_ORANGE    0xFD20
#define COLOR_BG        0x0000      // background: black
#define COLOR_GRID      0x39E7      // grid lines: mid-gray
#define COLOR_CURSOR    0xFFE0      // cursor highlight: yellow
#define COLOR_X         0xF800      // X pieces: red
#define COLOR_O         0x001F      // O pieces: blue
#define COLOR_WIN_LINE  0x07E0      // winning line: green

// ============================================================
//  Game state definitions
// ============================================================
#define PLAYER_NONE     0
#define PLAYER_X        1
#define PLAYER_O        2

#define MODE_PVP        0           // player vs player
#define MODE_PVC        1           // player vs computer

#define GAME_A          0
#define GAME_B          1

#define STATE_MENU      0
#define STATE_PLAYING   1
#define STATE_GAMEOVER  2

// ============================================================
//  Joystick ADC thresholds (12-bit ADC, center ~2048)
// ============================================================
#define JOY_LOW         800
#define JOY_HIGH        3200
#define JOY_CENTER_LOW  1400
#define JOY_CENTER_HIGH 2700

// Joystick pins
// X-axis: A2  on P6.1  (J1.2)
// Y-axis: A14 on P6.1  -- actually check: J3.26 = P4.2 = A9 on MSP430FR6989
// SEL:    P4.1 (J1.5)  -- digital input
// NOTE: Exact port/channel depends on which MSP430 variant you're using.
// The #defines below assume MSP430FR6989 + FR5994. Adjust if needed.
#define JOY_X_CHANNEL   ADC12INCH_10    // A10 per your lab manual
// Y channel: from pinout J3.26 -- you'll need to verify the analog channel
// Lab manual snippet showed X=A10/P9.2 and Y is one pin over.
// Placeholder: A11 — update with your lab manual's answer
#define JOY_Y_CHANNEL   ADC12INCH_11

// ============================================================
//  Buzzer (J4.40) — driven by Timer PWM
//  Adjust TB0/TA0 and pin depending on your MSP430 variant
// ============================================================
#define BUZZER_FREQ_MOVE    800     // Hz — short beep on move
#define BUZZER_FREQ_WIN     1200    // Hz — win jingle base
#define BUZZER_FREQ_LOSE    400     // Hz — loss/draw tone
#define BUZZER_FREQ_SWITCH  600     // Hz — game switch beep

// ============================================================
//  LCD SPI pins (from datasheet):
